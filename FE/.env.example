# Development (npm run dev): để trống, dùng Vite proxy
VITE_API_URL=

# Target proxy tới Django REST API
VITE_BE_PROXY_TARGET=http://127.0.0.1:8000

# Production build: trỏ thẳng backend
# VITE_API_URL=http://localhost:8000/

